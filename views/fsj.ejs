<%- include('partials/header', { title: title }) %>

<% 
  // Logik für das Hintergrundbild:
  // Wir definieren es hier oben, damit der HTML-Code sauber bleibt.
  const heroBg = (data && data.hero_image) ? getImg(data.hero_image) : '/images/FSJ2024.jpg';
%>

<main>
    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center" 
             style="background-image: url('<%= heroBg %>'); background-position: center; background-size: cover;">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder"><%- (data.hero_title || 'We want you!').replace(/\n/g, '<br>') %></h1>
            <p class="lead fs-4 mt-3"><%= data.hero_subtitle || 'Dein FSJ im Verein' %></p>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <h2 class="fw-bold mb-3"><%= data.intro_headline %></h2>
                    <p class="lead text-muted mb-4"><%= data.intro_text %></p>

                    <div class="row align-items-center g-5 py-4">
                        <div class="col-lg-12">
                            <h3 class="fw-bold">Deine FSJ-Aufgaben:</h3>
                            <ul class="list-unstyled">
                                
                                <% 
                                   if (data.tasks && data.tasks.length > 0) { 
                                     data.tasks.forEach(task => { 
                                       // FIX: Wir holen uns den Wert aus dem Objekt, egal wie der Key heißt (task_1, text, etc.)
                                       let taskText = task;
                                       if (typeof task === 'object' && task !== null) {
                                           // Nimmt den ersten Wert, den es im Objekt findet
                                           taskText = Object.values(task)[0];
                                       }
                                %>
                                    <li class="d-flex align-items-start mb-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" 
                                             class="bi bi-check-circle-fill me-2 flex-shrink-0" 
                                             style="color: #c8102e;" 
                                             viewBox="0 0 16 16">
                                             <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                        </svg>
                                        <span><%= taskText %></span>
                                    </li>
                                <%   }); 
                                   } else { %>
                                    <li class="text-muted">Keine Aufgaben definiert.</li>
                                <% } %>

                            </ul>
                        </div>
                    </div>

                    <div class="card bg-light border-0 p-4 mt-5 rounded-3">
                        <div class="card-body row">
                            <div class="col-md-6">
                                <h3 class="fw-bold">Das kannst Du erwarten:</h3>
                                <div class="cms-list-content">
                                    <%- data.benefits_list %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h3 class="fw-bold mt-4 mt-md-0">Das bringst Du mit:</h3>
                                <div class="cms-list-content">
                                    <%- data.requirements_list %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <h2 class="fw-bold">Interesse geweckt?</h2>
                        <p class="lead">Dann melde Dich für Fragen und Deine Bewerbung unter:</p>
                        
                        <% if (data.contact_phone) { %>
                            <h3 class="my-3">
                                <a href="tel:<%= data.contact_phone.replace(/\s/g,'') %>" class="text-dark text-decoration-none">
                                    <%= data.contact_phone %>
                                </a>
                            </h3>
                        <% } %>
                        
                        <% if (data.contact_email) { %>
                            <p class="lead">oder per E-Mail an:</p>
                            <a href="mailto:<%= data.contact_email %>" class="btn btn-danger btn-lg px-4 mt-2">
                                <%= data.contact_email %>
                            </a>
                        <% } %>
                        
                        <p class="mt-4 fw-bold">Wir freuen uns auf Deine Bewerbung!</p>
                    </div>

                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>