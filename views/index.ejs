<%- include('partials/header', { title: 'Startseite - SV Schefflenz' }) %>

<main>
    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center" style="background-image: url('/images/hero-placeholder.jpg');">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder">Meine Heimat. Mein Verein.</h1>
            <p class="lead fs-4 mt-3">Willkommen auf der offiziellen Website der Sportvereinigung Schefflenz.</p>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <h2 class="display-5 fw-bold text-center mb-5">Aktuelle News</h2>
            
            <div class="row g-4">
                <% if (news && news.length > 0) { %>
                    <% news.forEach(item => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card shadow-sm h-100">
                                <img src="<%= getImg(item.image) %>" class="card-img-top" style="height: 300px; object-fit: cover;" alt="<%= item.headline %>">
                                
                                <div class="card-body d-flex flex-column">
                                    <p class="card-text text-muted small mb-2">
                                        <%= new Date(item.date_posted).toLocaleDateString('de-DE') %>
                                    </p>
                                    <h3 class="card-title h5 fw-bold mb-3"><%= item.headline %></h3>
                                    <p class="card-text text-muted mb-4 line-clamp-3">
                                        <%= item.teaser %>
                                    </p>
                                    <a href="/news/<%= item.slug %>" class="fw-semibold club-color-text text-decoration-none mt-auto">Weiterlesen &rarr;</a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center text-muted">Keine aktuellen Nachrichten vorhanden.</div>
                <% } %>
            </div>

            <div class="text-center mt-5">
                 <a href="/news" class="btn club-color-bg text-white fw-bold py-2 px-4 rounded-pill text-uppercase">Alle News anzeigen</a>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>