<%- include('partials/header', { title: title }) %>

<% 
  // Hintergrundbild Logik
  const heroBg = (data && data.hero_image) ? getImg(data.hero_image) : '/images/hero-placeholder.jpg';
%>

<main>
    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center" 
             style="background-image: url('<%= heroBg %>'); background-position: center; background-size: cover;">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder"><%= data.headline || 'Kinderturnen' %></h1>
            <p class="lead fs-4 mt-3"><%= data.subline || 'Bewegung und Spaß für unsere Kleinsten' %></p>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-9">

                    <% if (data.group_image) { %>
                        <figure class="figure mb-4 w-100">
                            <img src="<%= getImg(data.group_image) %>" class="figure-img img-fluid rounded shadow-sm w-100" alt="Kinderturnen SVS">
                            <% if (data.group_image_caption) { %>
                                <figcaption class="figure-caption text-center mt-2"><%= data.group_image_caption %></figcaption>
                            <% } %>
                        </figure>
                    <% } %>

                    <div class="mt-4">
                        <% if (data.content_text) { %>
                            <%- data.content_text %>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="ph ph-smiley fs-1 text-muted mb-3"></i>
                                <h3 class="h5 fw-bold">Hier entstehen neue Inhalte</h3>
                                <p class="text-muted">Aktuell liegen noch keine detaillierten Informationen zum Kinderturnen vor.<br>Bitte schauen Sie später noch einmal vorbei.</p>
                            </div>
                        <% } %>
                    </div>

                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>