<%- include('partials/header', { title: title }) %>

<main>

    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center"
             style="background-image: url('/images/hero-placeholder.jpg'); background-position: center; background-size: cover;">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder">Kontakt</h1>
            <p class="lead fs-4 mt-3">Wir sind fuer euch da</p>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row g-5 align-items-start">

                <div class="col-lg-7">
                    <h2 class="fw-bold mb-1">Nachricht schreiben</h2>
                    <p class="text-muted mb-4">Wir antworten so schnell wie moeglich.</p>

                    <% if (success) { %>
                        <div class="alert alert-success" role="alert">
                            Deine Nachricht wurde gesendet!
                        </div>
                    <% } %>

                    <% if (error) { %>
                        <div class="alert alert-danger" role="alert">
                            Bitte alle Pflichtfelder ausfullen.
                        </div>
                    <% } %>

                    <form action="/kontakt" method="POST">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label fw-semibold">Name *</label>
                                <input type="text" class="form-control" name="name" required>
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label fw-semibold">E-Mail *</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Betreff</label>
                                <select class="form-select" name="betreff">
                                    <option value="">Bitte waehlen</option>
                                    <option>Allgemeine Anfrage</option>
                                    <option>Mitgliedschaft</option>
                                    <option>Fussball</option>
                                    <option>Volleyball</option>
                                    <option>Schuetzen</option>
                                    <option>Breitensport</option>
                                    <option>FSJ</option>
                                    <option>Sonstiges</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Nachricht *</label>
                                <textarea class="form-control" name="nachricht" rows="6" required></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="datenschutz" required>
                                    <label class="form-check-label small">
                                        Ich habe die <a href="/datenschutz">Datenschutzerklaerung</a> gelesen. *
                                    </label>
                                </div>
                            </div>
                            <div class="col-12 mt-2">
                                <button type="submit" class="btn club-color-bg text-white fw-bold px-5 py-2 rounded-pill">
                                    Nachricht senden
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <h3 class="fw-bold fs-5 mb-4">SV Schefflenz e.V.</h3>
                        <ul class="list-unstyled mb-0">
                            <% if (globals && globals.address) { %>
                                <li class="mb-2">
                                    <% var addrLines = globals.address.split('\n'); %>
                                    <% addrLines.forEach(function(l) { %>
                                        <%= l %><br>
                                    <% }); %>
                                </li>
                            <% } %>
                            <% if (globals && globals.email) { %>
                                <li>
                                    <a href="mailto:<%= globals.email %>" class="text-muted text-decoration-none"><%= globals.email %></a>
                                </li>
                            <% } %>
                        </ul>
                    </div>
                    <div class="card border-0 bg-light rounded-4 p-4">
                        <p class="small text-muted mb-0">
                            Fuer Abteilungsanfragen direkt die
                            <a href="#abteilungen" class="club-color-text text-decoration-none fw-semibold">Ansprechpartner</a>
                            weiter unten kontaktieren.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="abteilungen" class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Ansprechpartner</h2>
                <p class="text-muted">Direkter Kontakt zu den Abteilungen</p>
            </div>
            <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
                <% contacts.forEach(function(contact) { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:48px; height:48px; background-color: rgba(200,16,46,0.1);">
                                    <i class="ph-fill <%= contact.icon %> club-color-text fs-4"></i>
                                </div>
                                <div>
                                    <div class="fw-bold lh-1"><%= contact.department %></div>
                                    <% if (contact.role) { %>
                                        <div class="text-muted small"><%= contact.role %></div>
                                    <% } %>
                                </div>
                            </div>
                            <% if (contact.name) { %>
                                <p class="fw-semibold mb-2"><%= contact.name %></p>
                            <% } %>
                            <ul class="list-unstyled mb-0 mt-auto">
                                <% if (contact.email) { %>
                                    <li class="mb-1">
                                        <a href="mailto:<%= contact.email %>" class="text-muted text-decoration-none small">
                                            <i class="ph-fill ph-envelope club-color-text me-1"></i><%= contact.email %>
                                        </a>
                                    </li>
                                <% } %>
                                <% if (contact.phone) { %>
                                    <li>
                                        <a href="tel:<%= contact.phone %>" class="text-muted text-decoration-none small">
                                            <i class="ph-fill ph-phone club-color-text me-1"></i><%= contact.phone %>
                                        </a>
                                    </li>
                                <% } %>
                            </ul>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>

</main>

<%- include('partials/footer') %>
