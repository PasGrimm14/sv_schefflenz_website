<%- include('partials/header', { title: title }) %>

<main>
    <%-- ===== HERO ===== --%>
    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center"
             style="background-image: url('/images/hero-placeholder.jpg'); background-position: center; background-size: cover;">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder">Kontakt</h1>
            <p class="lead fs-4 mt-3">Wir sind für euch da – schreibt uns oder ruft an.</p>
        </div>
    </section>

    <%-- ===== KONTAKTFORMULAR + ALLGEMEINE INFO ===== --%>
    <section class="py-5">
        <div class="container">
            <div class="row g-5 align-items-start">

                <%-- LINKE SPALTE: Formular --%>
                <div class="col-lg-7">
                    <h2 class="fw-bold mb-1">Nachricht schreiben</h2>
                    <p class="text-muted mb-4">Wir antworten so schnell wie möglich.</p>

                    <% if (locals.success) { %>
                        <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
                            <i class="ph-fill ph-check-circle fs-4"></i>
                            <span>Deine Nachricht wurde erfolgreich gesendet. Wir melden uns bald!</span>
                        </div>
                    <% } %>

                    <% if (locals.error) { %>
                        <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                            <i class="ph-fill ph-warning-circle fs-4"></i>
                            <span>Beim Senden ist ein Fehler aufgetreten. Bitte versuche es später erneut.</span>
                        </div>
                    <% } %>

                    <form action="/kontakt" method="POST" novalidate>

                        <div class="row g-3">

                            <div class="col-sm-6">
                                <label for="name" class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="name" name="name"
                                       placeholder="Max Mustermann" required>
                            </div>

                            <div class="col-sm-6">
                                <label for="email" class="form-label fw-semibold">E-Mail <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="email" name="email"
                                       placeholder="max@beispiel.de" required>
                            </div>

                            <div class="col-12">
                                <label for="betreff" class="form-label fw-semibold">Betreff</label>
                                <select class="form-select" id="betreff" name="betreff">
                                    <option value="" selected>Bitte wählen…</option>
                                    <option value="Allgemeine Anfrage">Allgemeine Anfrage</option>
                                    <option value="Mitgliedschaft">Mitgliedschaft</option>
                                    <option value="Fußball Senioren">Fußball – Senioren</option>
                                    <option value="Fußball Jugend">Fußball – Jugend</option>
                                    <option value="Fußball Alte Herren">Fußball – Alte Herren</option>
                                    <option value="Volleyball">Volleyball</option>
                                    <option value="Schützen">Schützen</option>
                                    <option value="Breitensport">Breitensport</option>
                                    <option value="FSJ">FSJ</option>
                                    <option value="Sponsoring / Kooperation">Sponsoring / Kooperation</option>
                                    <option value="Sonstiges">Sonstiges</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label for="nachricht" class="form-label fw-semibold">Nachricht <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="nachricht" name="nachricht"
                                          rows="6" placeholder="Deine Nachricht…" required></textarea>
                            </div>

                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="datenschutz" name="datenschutz" required>
                                    <label class="form-check-label small" for="datenschutz">
                                        Ich habe die <a href="/datenschutz" class="club-color-text" target="_blank">Datenschutzerklärung</a>
                                        gelesen und stimme der Verarbeitung meiner Daten zu. <span class="text-danger">*</span>
                                    </label>
                                </div>
                            </div>

                            <div class="col-12 mt-2">
                                <button type="submit" class="btn club-color-bg text-white fw-bold px-5 py-2 rounded-pill">
                                    <i class="ph-bold ph-paper-plane-tilt me-2"></i>Nachricht senden
                                </button>
                            </div>

                        </div>
                    </form>
                </div>

                <%-- RECHTE SPALTE: Kurzinfos --%>
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <h3 class="fw-bold fs-5 mb-4">
                            <i class="ph-fill ph-buildings me-2 club-color-text"></i>SV Schefflenz e.V.
                        </h3>
                        <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
                            <% if (typeof globals !== 'undefined' && globals.address) { %>
                                <li class="d-flex align-items-start gap-3">
                                    <i class="ph-fill ph-map-pin fs-4 club-color-text flex-shrink-0 mt-1"></i>
                                    <span class="text-muted"><%- globals.address.replace(/\n/g, '<br>') %></span>
                                </li>
                            <% } else { %>
                                <li class="d-flex align-items-start gap-3">
                                    <i class="ph-fill ph-map-pin fs-4 club-color-text flex-shrink-0 mt-1"></i>
                                    <span class="text-muted">Musterstraße 1<br>74722 Schefflenz</span>
                                </li>
                            <% } %>

                            <% if (typeof globals !== 'undefined' && globals.email) { %>
                                <li class="d-flex align-items-start gap-3">
                                    <i class="ph-fill ph-envelope fs-4 club-color-text flex-shrink-0 mt-1"></i>
                                    <a href="mailto:<%= globals.email %>" class="text-muted text-decoration-none"><%= globals.email %></a>
                                </li>
                            <% } %>
                        </ul>
                    </div>

                    <div class="card border-0 bg-light rounded-4 p-4">
                        <p class="small text-muted mb-0">
                            <i class="ph-fill ph-info me-1 club-color-text"></i>
                            Für spezifische Abteilungsanfragen kannst du auch direkt die
                            <a href="#abteilungen" class="club-color-text text-decoration-none fw-semibold">Ansprechpartner</a>
                            weiter unten kontaktieren.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <%-- ===== ANSPRECHPARTNER ===== --%>
    <section id="abteilungen" class="py-5 bg-light">
        <div class="container">

            <div class="text-center mb-5">
                <h2 class="fw-bold">Ansprechpartner</h2>
                <p class="text-muted">Direkter Kontakt zu den einzelnen Abteilungen</p>
            </div>

            <% 
              // Kontakte aus dem CMS oder als Fallback-Array
              const contacts = (typeof data !== 'undefined' && data && data.contacts && data.contacts.length > 0)
                ? data.contacts
                : [
                    {
                      department: 'Vorstand',
                      icon: 'ph-star',
                      name: (typeof data !== 'undefined' && data && data.vorstand_name) ? data.vorstand_name : '',
                      role: (typeof data !== 'undefined' && data && data.vorstand_role) ? data.vorstand_role : '1. Vorsitzender',
                      email: (typeof data !== 'undefined' && data && data.vorstand_email) ? data.vorstand_email : '',
                      phone: (typeof data !== 'undefined' && data && data.vorstand_phone) ? data.vorstand_phone : '',
                    },
                    {
                      department: 'Fußball Senioren',
                      icon: 'ph-soccer-ball',
                      name: (typeof data !== 'undefined' && data && data.senioren_name) ? data.senioren_name : '',
                      role: (typeof data !== 'undefined' && data && data.senioren_role) ? data.senioren_role : 'Abteilungsleiter Fußball',
                      email: (typeof data !== 'undefined' && data && data.senioren_email) ? data.senioren_email : '',
                      phone: (typeof data !== 'undefined' && data && data.senioren_phone) ? data.senioren_phone : '',
                    },
                    {
                      department: 'Fußball Jugend',
                      icon: 'ph-soccer-ball',
                      name: (typeof data !== 'undefined' && data && data.jugend_name) ? data.jugend_name : '',
                      role: (typeof data !== 'undefined' && data && data.jugend_role) ? data.jugend_role : 'Jugendleiter',
                      email: (typeof data !== 'undefined' && data && data.jugend_email) ? data.jugend_email : '',
                      phone: (typeof data !== 'undefined' && data && data.jugend_phone) ? data.jugend_phone : '',
                    },
                    {
                      department: 'Schützen',
                      icon: 'ph-target',
                      name: (typeof data !== 'undefined' && data && data.schuetzen_name) ? data.schuetzen_name : '',
                      role: (typeof data !== 'undefined' && data && data.schuetzen_role) ? data.schuetzen_role : 'Oberschützenmeister',
                      email: (typeof data !== 'undefined' && data && data.schuetzen_email) ? data.schuetzen_email : '',
                      phone: (typeof data !== 'undefined' && data && data.schuetzen_phone) ? data.schuetzen_phone : '',
                    },
                    {
                      department: 'Volleyball',
                      icon: 'ph-volleyball',
                      name: (typeof data !== 'undefined' && data && data.volleyball_name) ? data.volleyball_name : '',
                      role: (typeof data !== 'undefined' && data && data.volleyball_role) ? data.volleyball_role : 'Abteilungsleiter Volleyball',
                      email: (typeof data !== 'undefined' && data && data.volleyball_email) ? data.volleyball_email : '',
                      phone: (typeof data !== 'undefined' && data && data.volleyball_phone) ? data.volleyball_phone : '',
                    },
                    {
                      department: 'Breitensport',
                      icon: 'ph-person-simple-run',
                      name: (typeof data !== 'undefined' && data && data.breitensport_name) ? data.breitensport_name : '',
                      role: (typeof data !== 'undefined' && data && data.breitensport_role) ? data.breitensport_role : 'Abteilungsleiter Breitensport',
                      email: (typeof data !== 'undefined' && data && data.breitensport_email) ? data.breitensport_email : '',
                      phone: (typeof data !== 'undefined' && data && data.breitensport_phone) ? data.breitensport_phone : '',
                    },
                    {
                      department: 'FSJ',
                      icon: 'ph-hand-heart',
                      name: (typeof data !== 'undefined' && data && data.fsj_name) ? data.fsj_name : '',
                      role: (typeof data !== 'undefined' && data && data.fsj_role) ? data.fsj_role : 'FSJ-Koordination',
                      email: (typeof data !== 'undefined' && data && data.fsj_email) ? data.fsj_email : '',
                      phone: (typeof data !== 'undefined' && data && data.fsj_phone) ? data.fsj_phone : '',
                    },
                  ];
            %>

            <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
                <% contacts.forEach(contact => { %>
                    <% if (contact.name || contact.email || contact.phone) { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 p-4">

                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:48px; height:48px; background-color: rgba(200,16,46,0.1);">
                                    <i class="ph-fill <%= contact.icon || 'ph-user' %> club-color-text fs-4"></i>
                                </div>
                                <div>
                                    <div class="fw-bold lh-1"><%= contact.department %></div>
                                    <% if (contact.role) { %>
                                        <div class="text-muted small"><%= contact.role %></div>
                                    <% } %>
                                </div>
                            </div>

                            <% if (contact.name) { %>
                                <p class="fw-semibold mb-2"><%= contact.name %></p>
                            <% } %>

                            <ul class="list-unstyled mb-0 d-flex flex-column gap-2 mt-auto">
                                <% if (contact.email) { %>
                                    <li>
                                        <a href="mailto:<%= contact.email %>"
                                           class="text-muted text-decoration-none small d-flex align-items-center gap-2">
                                            <i class="ph-fill ph-envelope club-color-text fs-5 flex-shrink-0"></i>
                                            <span class="text-truncate"><%= contact.email %></span>
                                        </a>
                                    </li>
                                <% } %>
                                <% if (contact.phone) { %>
                                    <li>
                                        <a href="tel:<%= contact.phone.replace(/\s/g,'') %>"
                                           class="text-muted text-decoration-none small d-flex align-items-center gap-2">
                                            <i class="ph-fill ph-phone club-color-text fs-5 flex-shrink-0"></i>
                                            <span><%= contact.phone %></span>
                                        </a>
                                    </li>
                                <% } %>
                            </ul>

                        </div>
                    </div>
                    <% } %>
                <% }); %>
            </div>

        </div>
    </section>

</main>

<%- include('partials/footer') %>
