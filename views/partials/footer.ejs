<footer class="text-white pt-5 pb-4 mt-auto" style="background-color: #c8102e;">
      <div class="container">
        <div class="row g-4 mb-4 align-items-center">
          
          <div class="col-lg-3 col-md-6 text-center text-md-start">
            <h5 class="fw-bold mb-3">SV Schefflenz</h5>
            <p class="text-white-50 mb-0">
              Seit 1921 die sportliche Heimat in unserer Gemeinde.
            </p>
          </div>
          
          <div class="col-lg-3 col-md-6 text-center">
            <h5 class="fw-bold mb-3">Navigation</h5>
            <ul class="list-unstyled mb-0">
              <li class="mb-2"><a href="/impressum" class="text-white-50 text-decoration-none">Impressum</a></li>
              <li class="mb-0"><a href="/datenschutz" class="text-white-50 text-decoration-none">Datenschutz</a></li>
            </ul>
          </div>
          
          <div class="col-lg-3 col-md-6 text-center text-lg-end mt-4 mt-lg-0">
             <% if (typeof globals !== 'undefined' && globals.footer_logo) { %>
                <img src="<%= getImg(globals.footer_logo.id || globals.footer_logo) %>" alt="SVS Logo" class="img-fluid" style="max-height: 120px;">
             <% } else { %>
                <img src="/images/Kleeblatt.png" alt="SVS Kleeblatt" class="img-fluid" style="max-height: 120px;">
             <% } %>
          </div>
          
          <div class="col-lg-3 col-md-6 text-center text-lg-end mt-4 mt-lg-0">
            <a href="https://www.lsvbw.de/sportwelten/sportjugend/freiwilliges_soziales_jahr/" target="_blank">
              <img src="/images/fsjbild.JPG" alt="FSJ beim SVS" class="img-fluid" style="max-height: 120px;">
            </a>
          </div>
        </div>

        <div class="border-top border-white border-opacity-25 pt-4 mt-4 text-center text-white-50 small">
          &copy; <%= new Date().getFullYear() %> SV Schefflenz e.V. Alle Rechte vorbehalten.
        </div>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        // Dropdown Klick-Verhalten
        const navDropdowns = document.querySelectorAll(".navbar .dropdown > .dropdown-toggle");
        navDropdowns.forEach(function (dropdownToggle) {
          dropdownToggle.addEventListener("click", function (e) {
            if (this.href && this.href !== "#" && this.href !== "javascript:void(0);" && window.innerWidth >= 992) {
              window.location.href = this.href;
            }
          });
        });
        
        // Service Worker (PWA)
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', () => {
             navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW failed', err));
          });
        }
      });
    </script>
  </body>
</html>