<%- include('partials/header', { title: title }) %>

<% 
  // Hintergrundbild Logik
  const heroBg = (data && data.hero_image) ? getImg(data.hero_image) : '/images/hero-placeholder.jpg';
%>

<main>
    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center" 
             style="background-image: url('<%= heroBg %>'); background-position: center; background-size: cover;">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder"><%= data.headline || 'Unsere Schiedsrichter' %></h1>
            <p class="lead fs-4 mt-3">Ohne Schiri kein Spiel – werde Teil unseres Teams!</p>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h2 class="fw-bold mb-4">Vorteil Schiri</h2>
                    <div class="lead text-muted mb-4">
                        <% if (data.intro_text) { %>
                            <%- data.intro_text %>
                        <% } else { %>
                            <p>Schiedsrichter zu sein ist mehr als nur Regeln überwachen. Es ist eine Schule für das Leben, ein Fitnessprogramm und ein Hobby, das dich persönlich weiterbringt.</p>
                        <% } %>
                    </div>
                    <a href="#kontakt" class="btn btn-danger btn-lg rounded-pill px-4">Jetzt Kontakt aufnehmen</a>
                </div>
                
                <div class="col-lg-6">
                    <% if (data.promo_image) { %>
                        <img src="<%= getImg(data.promo_image) %>" class="img-fluid rounded shadow-lg" alt="Vorteil Schiri DFB Kampagne">
                    <% } %>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Warum Schiri werden?</h2>
                <p class="text-muted">Das bringt dir das Amt an der Pfeife</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm text-center py-4 px-3">
                        <div class="mb-3">
                            <i class="ph-fill ph-brain text-danger" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="fw-bold">Persönlichkeit</h5>
                        <ul class="list-unstyled text-muted mt-3 mb-0 small text-start mx-auto" style="max-width: 200px;">
                            <li class="mb-2"><i class="ph-bold ph-check text-success me-2"></i>Entscheidungsfreude</li>
                            <li class="mb-2"><i class="ph-bold ph-check text-success me-2"></i>Durchsetzungsvermögen</li>
                            <li><i class="ph-bold ph-check text-success me-2"></i>Teamfähigkeit</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm text-center py-4 px-3">
                        <div class="mb-3">
                            <i class="ph-fill ph-heart text-danger" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="fw-bold">Emotion</h5>
                        <ul class="list-unstyled text-muted mt-3 mb-0 small text-start mx-auto" style="max-width: 200px;">
                            <li class="mb-2"><i class="ph-bold ph-check text-success me-2"></i>Selbstvertrauen</li>
                            <li class="mb-2"><i class="ph-bold ph-check text-success me-2"></i>Spaß & Teilhabe</li>
                            <li><i class="ph-bold ph-check text-success me-2"></i>Umgang mit Menschen</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm text-center py-4 px-3">
                        <div class="mb-3">
                            <i class="ph-fill ph-person-simple-run text-danger" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="fw-bold">Gesundheit</h5>
                        <ul class="list-unstyled text-muted mt-3 mb-0 small text-start mx-auto" style="max-width: 200px;">
                            <li class="mb-2"><i class="ph-bold ph-check text-success me-2"></i>Sportliche Aktivität</li>
                            <li><i class="ph-bold ph-check text-success me-2"></i>Stressresistenz</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm text-center py-4 px-3">
                        <div class="mb-3">
                            <i class="ph-fill ph-ticket text-danger" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="fw-bold">Vergütung</h5>
                        <ul class="list-unstyled text-muted mt-3 mb-0 small text-start mx-auto" style="max-width: 200px;">
                            <li class="mb-2"><i class="ph-bold ph-check text-success me-2"></i>Freikarten (DFB - und Kreisebene)</li>
                            <li><i class="ph-bold ph-check text-success me-2"></i>Aufwandsentschädigung</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="kontakt" class="py-5">
        <div class="container">
            <div class="card bg-white border-0 shadow overflow-hidden">
                <div class="row g-0">
                    <% if (data.contact_image) { %>
                        <div class="col-md-4 position-relative">
                            <img src="<%= getImg(data.contact_image) %>" class="img-fluid h-100 w-100 object-fit-cover" style="min-height: 300px;" alt="Ansprechpartner">
                        </div>
                    <% } %>
                    
                    <div class="col-md-<%= data.contact_image ? '8' : '12' %> d-flex align-items-center bg-danger text-white">
                        <div class="card-body p-5">
                            <h3 class="fw-bold mb-3"><%= data.contact_headline || 'Interesse geweckt?' %></h3>
                            <p class="fs-5 opacity-75 mb-4">
                                <%= data.contact_text || 'Wir unterstützen dich bei der Ausbildung und den ersten Spielen. Melde dich einfach unverbindlich bei uns!' %>
                            </p>
                            
                            <div class="d-flex flex-column gap-3">
                                <% if (data.contact_person_name) { %>
                                    <div class="d-flex align-items-center">
                                        <i class="ph-fill ph-user fs-4 me-3"></i>
                                        <span class="fs-5 fw-semibold"><%= data.contact_person_name %></span>
                                    </div>
                                <% } %>

                                <% if (data.contact_email) { %>
                                    <div class="d-flex align-items-center">
                                        <i class="ph-fill ph-envelope fs-4 me-3"></i>
                                        <a href="mailto:<%= data.contact_email %>" class="text-white text-decoration-none fs-5"><%= data.contact_email %></a>
                                    </div>
                                <% } %>

                                <% if (data.contact_phone) { %>
                                    <div class="d-flex align-items-center">
                                        <i class="ph-fill ph-phone fs-4 me-3"></i>
                                        <a href="tel:<%= data.contact_phone %>" class="text-white text-decoration-none fs-5"><%= data.contact_phone %></a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>