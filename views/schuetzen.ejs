<%- include('partials/header', { title: title }) %>

<% 
  // Hintergrundbild für den Header (Hero)
  // Falls im CMS ('hero_image') nichts hinterlegt ist, nehmen wir ein Fallback-Bild
  const heroBg = (data && data.hero_image) ? getImg(data.hero_image) : '/images/hero-placeholder.jpg';
%>

<main>
    <section class="hero-bg position-relative d-flex align-items-center justify-content-center text-white text-center" 
             style="background-image: url('<%= heroBg %>'); background-position: center; background-size: cover;">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
        <div class="position-relative px-3">
            <h1 class="display-3 fw-bolder"><%= data.headline || 'Geschichte der Schützenabteilung' %></h1>
            
            <% if (data.intro_text) { %>
                <p class="lead fs-4 mt-3"><%= data.intro_text %></p>
            <% } %>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-9">

                    <% if (data.block_1_text) { %>
                        <div class="mb-4">
                            <%- data.block_1_text %>
                        </div>
                    <% } %>

                    <% if (data.image_1) { %>
                        <figure class="figure my-4 w-100">
                            <img src="<%= getImg(data.image_1) %>" class="figure-img img-fluid rounded shadow-sm w-100" alt="Historisches Bild 1">
                            <% if (data.image_1_caption) { %>
                                <figcaption class="figure-caption text-center"><%= data.image_1_caption %></figcaption>
                            <% } %>
                        </figure>
                    <% } %>

                    <% if (data.block_2_text) { %>
                        <div class="mb-4">
                            <%- data.block_2_text %>
                        </div>
                    <% } %>

                    <% if (data.image_2) { %>
                        <figure class="figure my-4 w-100">
                            <img src="<%= getImg(data.image_2) %>" class="figure-img img-fluid rounded shadow-sm w-100" alt="Historisches Bild 2">
                            <% if (data.image_2_caption) { %>
                                <figcaption class="figure-caption text-center"><%= data.image_2_caption %></figcaption>
                            <% } %>
                        </figure>
                    <% } %>

                    <% if (data.block_3_text) { %>
                        <div class="mb-4">
                            <%- data.block_3_text %>
                        </div>
                    <% } %>

                </div>
            </div>
        </div>
    </section>

    <section id="kontakt" class="py-5">
        <div class="container">
            <div class="card bg-white border-0 shadow overflow-hidden">
                <div class="row g-0">
                    <% if (data.contact_image) { %>
                        <div class="col-md-4 position-relative">
                            <img src="<%= getImg(data.contact_image) %>" class="img-fluid h-100 w-100 object-fit-cover" style="min-height: 300px;" alt="Ansprechpartner">
                        </div>
                    <% } %>
                    
                    <div class="col-md-<%= data.contact_image ? '8' : '12' %> d-flex align-items-center bg-danger text-white">
                        <div class="card-body p-5">
                            <h3 class="fw-bold mb-3"><%= data.contact_headline || 'Interesse geweckt?' %></h3>
                            <p class="fs-5 opacity-75 mb-4">
                                <%= data.contact_text || 'Wir freuen uns auf neue Interessenten und zukünftige Schützen. Kommt einfach vorbei und traut Euch mal den Schießsport auszuprobieren. Wir geben gerne Schützenhilfe. Zu Fragen steht unser Oberschützenmeister der Schützenabteilung Jochen Zachow gerne zur Verfügung:' %>
                            </p>
                            
                            <div class="d-flex flex-column gap-3">
                                <% if (data.contact_person_name) { %>
                                    <div class="d-flex align-items-center">
                                        <i class="ph-fill ph-user fs-4 me-3"></i>
                                        <span class="fs-5 fw-semibold"><%= data.contact_person_name %></span>
                                    </div>
                                <% } %>

                                <% if (data.contact_email) { %>
                                    <div class="d-flex align-items-center">
                                        <i class="ph-fill ph-envelope fs-4 me-3"></i>
                                        <a href="mailto:<%= data.contact_email %>" class="text-white text-decoration-none fs-5"><%= data.contact_email %></a>
                                    </div>
                                <% } %>

                                <% if (data.contact_phone) { %>
                                    <div class="d-flex align-items-center">
                                        <i class="ph-fill ph-phone fs-4 me-3"></i>
                                        <a href="tel:<%= data.contact_phone %>" class="text-white text-decoration-none fs-5"><%= data.contact_phone %></a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
